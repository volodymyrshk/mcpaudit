            {
              "id": "TS-004",
              "name": "Serversupportsdynamictoollistchanges",
              "shortDescription": {
                "text": "Server supports dynamic tool list changes"
              },
              "fullDescription": {
                "text": "The server has listChanged=true for tools, meaning it can dynamically add or remove tools during a session. This is a known attack vector: a server could initially present benign tools to pass security review, then inject malicious tools mid-session (tool poisoning / rug pull attack)."
              },
              "help": {
                "text": "Clients should re-validate the tool list after each tools/list_changed notification. Consider implementing a tool allowlist that restricts which tools can be called regardless of dynamic changes. Alert users when the tool list changes mid-session.",
                "markdown": "**Remediation:** Clients should re-validate the tool list after each tools/list_changed notification. Consider implementing a tool allowlist that restricts which tools can be called regardless of dynamic changes. Alert users when the tool list changes mid-session."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "properties": {
                "severity": "MEDIUM",
                "module": "transport-security",
                "security-severity": "6.5",
                "tags": [
                  "security",
                  "mcp",
                  "transport-security",
                  "CWE-345",
                  "NIST SP 800-171:3.14.2",
                  "SOC 2 TSC:CC7.1",
                  "OWASP ASVS:V10.3.2"
                ]
              }
            },
