            {
              "id": "TP-003-write-operations",
              "name": "Toolswithwriteoperationsnamingpatterns",
              "shortDescription": {
                "text": "Tools with write-operations naming patterns"
              },
              "fullDescription": {
                "text": "2 tool(s) have names suggesting write-operations capabilities. These tools may pose elevated security risks if not properly constrained."
              },
              "help": {
                "text": "Review these tools for appropriate input validation, access controls, and documentation of security implications. Consider restricting tool availability via MCP server configuration.",
                "markdown": "**Remediation:** Review these tools for appropriate input validation, access controls, and documentation of security implications. Consider restricting tool availability via MCP server configuration."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "severity": "LOW",
                "module": "tool-permissions",
                "security-severity": "5.3",
                "tags": [
                  "security",
                  "mcp",
                  "tool-permissions",
                  "CWE-732",
                  "NIST SP 800-171:3.1.2",
                  "SOC 2 TSC:CC6.3",
                  "OWASP ASVS:V4.1.3"
                ]
              }
            },
