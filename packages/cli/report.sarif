          "ruleId": "TS-004",
          "ruleIndex": 12,
          "level": "warning",
          "message": {
            "text": "Server supports dynamic tool list changes: The server has listChanged=true for tools, meaning it can dynamically add or remove tools during a session. This is a known attack vector: a server could initially present benign tools to pass security review, then inject malicious tools mid-session (tool poisoning / rug pull attack)."
          },
          "locations": [
            {
              "logicalLocations": [
                {
                  "name": "secure-filesystem-server",
                  "kind": "mcpServer",
                  "fullyQualifiedName": "secure-filesystem-server"
                }
              ]
            }
          ],
          "fixes": [
            {
              "description": {
                "text": "Clients should re-validate the tool list after each tools/list_changed notification. Consider implementing a tool allowlist that restricts which tools can be called regardless of dynamic changes. Alert users when the tool list changes mid-session."
              }
            }
          ],
          "properties": {
            "severity": "MEDIUM",
            "module": "transport-security",
            "evidence": {
              "toolsCapability": {
                "listChanged": true
              }
            }
          }
        },
